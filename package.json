{
  "name": "forum",
  "version": "0.1.0",
  "private": true,
  "description": "A local multi-actor AI forum for LM Studio.",
  "type": "module",
  "scripts": {
    "server": "node server.js",
    "dev": "vite --config vite.config.js",
